# Public host served by your reverse proxy.
SCHEDULER_HOST=scheduler.example.com

# Existing external Docker network used by Tunarr, Jellyfin, and the scheduler.
SCHEDULER_NETWORK=flixwolf_media

# Swarm placement. Set to worker/manager depending on your deployment.
SCHEDULER_NODE_ROLE=manager

# Traefik settings used by docker-compose.yml and docker-stack.yml.
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=letsencrypt
TRAEFIK_MIDDLEWARES=security-headers@file

# Optional environment overrides for first-run config placeholders.
JELLYFIN_API_KEY=
JELLYFIN_USER_ID=
